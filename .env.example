# Database (MySQL via docker-compose)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mindful
DB_PASSWORD=mindful
DB_NAME=mindful_news

# Scraping
BULK_TARGET_PER_SOURCE=3000
HOURLY_LIMIT_PER_SOURCE=50
LOG_LEVEL=20
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0

# OpenAI classification
OPENAI_API_KEY=your-key-here
CLASSIFICATION_MODEL=gpt-5.4-mini
PROMPT_MODEL=gpt-5.5
